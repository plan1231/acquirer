---
import Layout from '@/layouts/Layout.astro';
import '@/styles/global.css';
import { jobRunner } from '@/lib/jobs';

const formatDate = (date: Date | null) =>
  date ? new Intl.DateTimeFormat('en-US', { dateStyle: 'medium', timeStyle: 'short' }).format(date) : 'N/A';

const toJson = (value: object) => {
  try {
    return JSON.stringify(value, null, 2);
  } catch {
    return '{"error":"Could not serialize job input"}';
  }
};

const allJobs = jobRunner.getJobs();
const statusCounts = allJobs.reduce(
  (counts, job) => {
    counts[job.status] += 1;
    return counts;
  },
  { pending: 0, running: 0, complete: 0, failed: 0 }
);
---

<Layout title="Acquirer Job Queue">
  <main class="min-h-screen bg-slate-950 text-slate-100">
    <div class="mx-auto flex max-w-7xl flex-col gap-6 p-6 md:p-10">
      <header class="rounded-3xl border border-cyan-400/30 bg-gradient-to-r from-slate-900 to-slate-800 p-6 shadow-2xl shadow-cyan-900/30">
        <p class="text-sm uppercase tracking-[0.24em] text-cyan-300">Acquirer</p>
        <h1 class="mt-2 text-3xl font-semibold md:text-4xl">Job Queue Status</h1>
        <p class="mt-2 text-slate-300">Live in-process view of queued and completed jobs for this server instance.</p>
        <a href="/" class="mt-3 inline-block text-sm text-cyan-200 underline decoration-cyan-400/70 underline-offset-4">
          Back to dashboard
        </a>
      </header>

      <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        <article class="rounded-2xl border border-slate-700 bg-slate-900/70 p-5 lg:col-span-1">
          <p class="text-sm uppercase tracking-wider text-slate-400">Total Jobs</p>
          <p class="mt-3 text-3xl font-semibold text-cyan-300">{allJobs.length}</p>
        </article>
        <article class="rounded-2xl border border-slate-700 bg-slate-900/70 p-5">
          <p class="text-sm uppercase tracking-wider text-slate-400">Pending</p>
          <p class="mt-3 text-3xl font-semibold text-slate-200">{statusCounts.pending}</p>
        </article>
        <article class="rounded-2xl border border-slate-700 bg-slate-900/70 p-5">
          <p class="text-sm uppercase tracking-wider text-slate-400">Running</p>
          <p class="mt-3 text-3xl font-semibold text-blue-300">{statusCounts.running}</p>
        </article>
        <article class="rounded-2xl border border-slate-700 bg-slate-900/70 p-5">
          <p class="text-sm uppercase tracking-wider text-slate-400">Complete</p>
          <p class="mt-3 text-3xl font-semibold text-emerald-300">{statusCounts.complete}</p>
        </article>
        <article class="rounded-2xl border border-slate-700 bg-slate-900/70 p-5">
          <p class="text-sm uppercase tracking-wider text-slate-400">Failed</p>
          <p class="mt-3 text-3xl font-semibold text-rose-300">{statusCounts.failed}</p>
        </article>
      </section>

      <section class="rounded-2xl border border-slate-700 bg-slate-900/60 p-5">
        <h2 class="text-xl font-semibold">All Jobs</h2>
        {
          allJobs.length === 0 ? (
            <p class="mt-3 text-sm text-slate-400">No jobs have been queued yet.</p>
          ) : (
            <ul class="mt-4 space-y-3">
              {allJobs.map((job) => (
                <li class="rounded-xl border border-slate-800 bg-slate-950/80 p-4">
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                    <p class="text-lg font-semibold">#{job.id}</p>
                    <p class="rounded-full border border-slate-700 px-2 py-0.5 text-xs uppercase tracking-wider text-slate-200">
                      {job.status}
                    </p>
                    <p class="text-sm text-cyan-300">{job.constructor.name}</p>
                  </div>
                  <dl class="mt-3 grid gap-3 md:grid-cols-2">
                    <div>
                      <dt class="text-xs uppercase tracking-wider text-slate-400">Describe()</dt>
                      <dd class="mt-1 rounded-lg border border-slate-800 bg-slate-900/70 px-3 py-2 text-sm text-slate-100">
                        {job.describe()}
                      </dd>
                    </div>
                    <div>
                      <dt class="text-xs uppercase tracking-wider text-slate-400">Input Object</dt>
                      <dd>
                        <pre class="mt-1 overflow-x-auto rounded-lg border border-slate-800 bg-slate-900/70 px-3 py-2 text-xs text-slate-100">{toJson(job.input)}</pre>
                      </dd>
                    </div>
                    <div>
                      <dt class="text-xs uppercase tracking-wider text-slate-400">Created</dt>
                      <dd class="mt-1 text-sm text-slate-300">{formatDate(job.createdAt)}</dd>
                    </div>
                    <div>
                      <dt class="text-xs uppercase tracking-wider text-slate-400">Finished</dt>
                      <dd class="mt-1 text-sm text-slate-300">{formatDate(job.finishedAt)}</dd>
                    </div>
                  </dl>
                </li>
              ))}
            </ul>
          )
        }
      </section>
    </div>
  </main>
</Layout>
