# S3 Configuration                                                                           │
│ S3_BUCKET=your-bucket-name                                                                   │
│ S3_ACCESS_KEY=your-access-key                                                                │
│ S3_SECRET_KEY=your-secret-key                                                                │
│ S3_REGION=us-east-1                                                                          │
│ S3_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com                                           │
│                                                                                              │
│ # Database                                                                                   │
│ DATABASE_URL=file://user:password@localhost:5432/dbname       